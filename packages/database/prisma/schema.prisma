generator client{
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default("main")
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model About {
  id        String   @id @default("main")
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimelineEntry {
  id          String   @id @default(cuid())
  month       String
  year        String
  title       String
  description String   @db.Text
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  name      String
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Certification {
  id        String   @id @default(cuid())
  title     String
  issuer    String?
  date      String?
  imageUrl  String?
  type      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id        String   @id @default("main")
  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quote {
  id        String   @id @default("main")
  text      String   @db.Text
  author    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visitor {
  id               String    @id @default(cuid())
  timestamp        DateTime  @default(now())
  browser          String?
  operatingSystem  String?
  deviceType       String?
  screenResolution String?
  referrer         String?
  country          String?
  sessionDuration  Int?
  entryTime        DateTime  @default(now())
  exitTime         DateTime?
}

model AdminUser {
  id        String   @id @default("main")
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
